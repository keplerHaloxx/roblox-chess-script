        "@typescript-eslint/eslint-plugin": "8.59.1",
        "@typescript-eslint/parser": "8.59.1",
        "cross-env": "10.1.0",
        "eslint": "10.2.1",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-roblox-ts": "1.4.0",
        "mkdirp": "3.0.1",
        "prettier": "3.8.3",
        "roblox-ts": "3.0.0",
        "typescript": "5.9.3"
    },
    "dependencies": {
