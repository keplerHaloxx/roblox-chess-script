{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "roblox-chess-script",
  "version": "2.0.0",
  "identifier": "me.haloxx.roblox-chess-script",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "roblox-chess-script",
        "width": 920,
        "label": "main",
        "height": 640,
        "minWidth": 920,
        "minHeight": 640,
        "maxWidth": 920,
        "maxHeight": 640,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
